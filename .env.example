# Server
PORT=3000

# Logging: JSON for aggregators (Datadog, SLS, etc.), pretty for local dev
# LOG_FORMAT=json   # default: raw JSON, one line per log
# LOG_FORMAT=pretty # human-readable with colors
# LOG_LEVEL=info    # trace, debug, info, warn, error
NODE_ENV=development

# Logging
LOG_LEVEL=info
# Set to "pretty" for local dev, "json" for production
LOG_FORMAT=pretty

# Database - shared host/port (same MySQL instance)
DB_HOST=localhost
DB_PORT=3306

# pg-middleware - read-only
DB_USERNAME=ai_readonly
DB_PASSWORD=your_password
DB_DATABASE=

# AI logs - read-write user for usage logs
DB_AI_USERNAME=ai_logs_rw
DB_AI_PASSWORD=your_password
DB_AI_DATABASE=

# Path to the schema JSON file (relative to project root)
SCHEMA_PATH=schema/SCHEMA_V1.json

# JWT (must match pg-middleware LOGIN_SECRET for /ask auth)
JWT_SECRET=change_me
# LOGIN_SECRET=  # alternative, same as pg-middleware

# LLM encryption key — AES-256-GCM key for API keys stored in llm_api_keys table.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LLM_ENCRYPTION_KEY=your_64_hex_char_key_here

# LLM API keys are stored ENCRYPTED in the llm_api_keys table, not in env vars.
# Seed the table using the helper script:
#   node scripts/seed-llm-keys.js
#
# Columns: provider_code (anthropic|openai|qwen|ollama), api_key (encrypted), base_url (nullable)
#
# Legacy env-var keys below are only kept for reference — they are no longer read by the app:
# ANTHROPIC_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
# QWEN_API_KEY=sk-...
# QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Phase 4: Multi-LLM defaults (until company_llm_config is used)
# Provider codes: anthropic | openai | qwen | ollama (must match llm_api_keys.provider_code)
LLM_SQL_PROVIDER=openai
LLM_SQL_MODEL=gpt-4o
LLM_ANSWER_PROVIDER=openai
LLM_ANSWER_MODEL=gpt-4o
# Anthropic example:
# LLM_SQL_PROVIDER=anthropic
# LLM_SQL_MODEL=claude-sonnet-4-6
# LLM_ANSWER_PROVIDER=anthropic
# LLM_ANSWER_MODEL=claude-sonnet-4-6

# Phase 5: Performance and UX
# REDIS_URL=redis://localhost:6379  # Optional: cache + session storage
# DBQA_CACHE_TTL=3600               # Cache TTL in seconds (default 3600)
# SCHEMA_PRUNING_ENABLED=true       # Keyword-based schema pruning (default true)

# Schema file storage backend (default: local)
# local  → reads from SCHEMA_PATH on the local filesystem (bind mount in Docker Swarm)
# s3     → reads from S3_BUCKET using SCHEMA_PATH as the S3 object key (Kubernetes/EKS)
STORAGE_BACKEND=local

# Path to the schema JSON file.
# local backend: absolute path to a bind-mounted file, or relative path from project root.
# s3 backend:    S3 object key (e.g. schema/SCHEMA_V1.json)
SCHEMA_PATH=schema/SCHEMA_V1.json

# S3 settings (only required when STORAGE_BACKEND=s3)
# S3_BUCKET=kcic-pg-middleware-ai
# S3_REGION=ap-southeast-3
# S3_ACCESS_KEY_ID=           # omit to use IAM role / IRSA on EKS
# S3_SECRET_ACCESS_KEY=
